# venv / Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Реальные данные спектрометра — НЕ в git (N42 может содержать GPS/метаданные устройства)
sample_data/*.n42
# Спектрограммы RadiaCode (.rcspg, JSON: deviceId/координаты/время) — тоже не в git
sample_data/*.rcspg
*.rcspg
# Нативные waterfall AtomSpectra (.aswf, заголовок: serial/IP-источник) — тоже не в git
sample_data/*.aswf
*.aswf
# Тестовые фикстуры — разрешаем явно
!tests/data/*.aswf

# Логи прогона (run.bat пишет stderr сюда)
*.log

# Сборка PyInstaller
build/
dist/
# #REL-9: старый билд-артефакт v0.1.7 (dist/ ловит только текущий каталог) — не в git
dist_v017/
*.spec
# #186: рецепт сборки exe (#184/#185) версионируется — исключение из *.spec
!waterfall-viewer.spec
# Релизные архивы (грузятся в GitHub Releases, не версионируются в git)
*.zip
# Артефакты прогонов (build_log.txt от PyInstaller, вывод pytest)
build_log.txt
test_out.txt

# Сборка пакета (pip wheel / setuptools build)
*.egg-info/

# IDE / прочее
.vscode/
.idea/

# graphify — регенерируемая графовая карта проекта (graphify update .)
graphify-out/

# Кэш IAEA LiveChart (сырые ENSDF CSV, скачиваются по кнопке; офлайн-воспроизводимость) — не в git
awf/data/iaea_cache/

# Промежуточные артефакты fetch_missing_nuclides.py (#86): кэш кандидатов + отчёт прогона.
# Регенерируются скриптом из сети; в библиотеку уже слиты (nuclides.json). Не в git.
scripts/_missing_candidates.json
scripts/_missing_report.txt

# Локальные dev-артефакты сессий разработки пиков (#107–#121) — НЕ в публичный репо.
# proto_peaks3d.py хардкодит локальный путь с IP-источником (PII); _proto_out — его вывод
# с IP в именах файлов; audit/ и scripts/ollama/_* — служебные черновики/Ollama-генерация.
audit/
scripts/_proto_out/
scripts/proto_peaks3d.py
tests/test_proto_peaks3d.py
scripts/_*
# Диагностические скрипты сессий #114/#130 — грузят реальные .aswf через argv (PII), dev-only.
# ВАЖНО: каталог пишется со слешем (scripts/diag/), а не scripts/diag_* — иначе паттерн не ловит подпапку.
scripts/diag_*
scripts/diag/
scripts/ollama/_*
# #REL-9: одноразовый Ollama-генератор v4-теста (dev-only, как _spec) — не в публичный репо
scripts/ollama/gen_test_aswf_v4.py
